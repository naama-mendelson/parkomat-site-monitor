# ==========================================================
# .env.test — סביבת הבדיקות
# ==========================================================
# העתק לקובץ בשם .env.test (בלי .example) ומלא את ה-URL.
# .env.test מוחרג מ-git. לעולם אל תשים כאן כתובת של פרודקשן.
#
# מאיפה משיגים את ה-URL:
#   Supabase → הפרויקט של הבדיקות → Connect → Transaction pooler (port 6543)
#   בדיוק כמו בפרודקשן — כדי שהבדיקות ירוצו מול אותו סוג חיבור.
#
# 🔒 הגנה: הפקודות test:db:* מסרבות לרוץ אלא אם המסד מסומן מבפנים כמסד
#    בדיקות (settings['environment'] = 'test'). הסימון נוצר ב-test:db:init.
#    לפרודקשן אין סימון כזה — ולכן גם URL שהודבק לכאן בטעות לא יזיק.
#    ראה master/db/test-guard.js.
# ==========================================================

DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ---- MQTT ----
# בדיקות אינן מתחברות ל-HiveMQ האמיתי. אם בדיקה כן צריכה broker,
# השתמש ב-credentials נפרדים — לא באלה של הפרודקשן.
HIVEMQ_HOST=
HIVEMQ_PORT=8883
MASTER_USERNAME=
MASTER_PASSWORD=
MASTER_CLIENT_ID=parkomat-master-test

DASHBOARD_ORIGIN=http://localhost:5173

# ---- עוזר ה-AI ----
# מפתח מ-console.groq.com (חינמי). בלעדיו השרת עולה תקין ו-/api/chat מחזיר 503.
GROQ_API_KEY=
# אופציונלי: GROQ_MODEL (ברירת מחדל llama-3.3-70b-versatile)
