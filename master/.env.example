# העתק לקובץ בשם .env באותה תיקייה ומלא את הערכים האמיתיים.
# הקובץ .env מוחרג מגיט (.gitignore) — הסודות לא נכנסים לריפו.
# npm start טוען אותו אוטומטית (node --env-file-if-exists).

# --- חיבור ל-HiveMQ (חובה) ---
HIVEMQ_HOST=your-instance.s1.eu.hivemq.cloud
HIVEMQ_PORT=8883
MASTER_USERNAME=your-username
MASTER_PASSWORD=your-password

# --- חיבור למסד הנתונים (חובה) ---
# PostgreSQL ב-Supabase. בלי המשתנה הזה השרת לא עולה בכלל.
#
# ⚠️ חשוב: יש להשתמש ב-connection pooler, לא בחיבור הישיר.
# החיבור הישיר (db.<ref>.supabase.co) הוא IPv6 בלבד, ורוב הרשתות
# והשרתים הם IPv4 — הוא פשוט לא ייפתר (ENOTFOUND).
#
# הפורט קובע את המצב:
#   6543 = transaction mode  ← זה מה שאנחנו משתמשים בו
#   5432 = session mode      ← תקרה של 15 חיבורים לכל הפרויקט; נגמרת מהר
#
# את המחרוזת המדויקת מעתיקים מ-Supabase: Project → Connect → Transaction pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- אופציונלי ---
# מזהה הלקוח מול הברוקר. שני מופעי Master עם אותו מזהה ינתקו זה את זה.
MASTER_CLIENT_ID=master

# מקור הדשבורד, לצורך CORS.
DASHBOARD_ORIGIN=http://localhost:5173
